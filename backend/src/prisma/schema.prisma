generator client {
    provider = "prisma-client-js"
    previewFeatures = ["fullTextSearch"]
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
    id           String   @id @default(uuid())
    serialNumber Int      @unique @default(autoincrement())
    nick         String   @unique
    firstname    String
    lastname     String
    password     String
    createdAt    DateTime @default(now())
}
