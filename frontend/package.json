{
  "name": "@authwithback/frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "prettify": "prettier --log-level warn --cache --write \"{src/**/*,*}. {ts,tsx,js,json,yml,scss}\" \"!**/{node_modules, dist}/**/*\"",
    "types": "tsc --noEmit --project ./tsconfig.json && tsc --noEmit --project ./tsconfig.app.json",
    "stylecheck": "sass --update -q ./src:./node_modules/.cache/.stylecheck"
  },
  "dependencies": {
    "@authwithback/backend": "workspace:*",
    "@tanstack/react-query": "4.32.6",
    "@trpc/client": "10.37.1",
    "@trpc/react-query": "10.37.1",
    "classnames": "^2.5.1",
    "formik": "^2.4.9",
    "formik-validator-zod": "^2.2.0",
    "include-media": "^2.0.0",
    "js-cookie": "3.0.5",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-infinite-scroller": "^1.2.6",
    "react-router-dom": "^7.15.1",
    "reset-css": "^5.0.2",
    "sass": "^1.100.0",
    "zod": "^4.4.3",
    "zod-formik-adapter": "^2.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/js-cookie": "3.0.3",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-infinite-scroller": "^1.2.5",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
